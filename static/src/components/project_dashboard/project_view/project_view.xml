<templates xml:space="preserve">
<t t-name="society_management.project_view">

    <div class="header">
        <h1>Task Dashboard</h1>

        <div class="filters">

            <button class="create_project" >
                New Task
            </button>

             <!-- SEARCH -->
            <input placeholder="Search task..." />

            <!-- FILTER STATUS -->
            <button>All</button>
            <button>ToDo</button>
            <button>Pending</button>
            <button>Done</button>

        </div>

        <!-- ================= PROJECT STATS ================= -->
        <div class="stats_container">

            <div class="stat_card total_tasks">
                <div class="icon"><i class="fa fa-file-text-o"/></div>
                <div class="info">
                    <span class="label">All Tasks</span>
                    <span class="number"></span>
                </div>
            </div>

            <div class="stat_card total_draft">
                <div class="icon"><i class="fa fa-file-text-o"/></div>
                <div class="info">
                    <span class="label">ToDo</span>
                    <span class="number"></span>
                </div>
            </div>

            <div class="stat_card total_progress">
                <div class="icon"><i class="fa fa-spinner"/></div>
                <div class="info">
                    <span class="label">Pending</span>
                    <span class="number"></span>
                </div>
            </div>

            <div class="stat_card total_done">
                <div class="icon"><i class="fa fa-check"/></div>
                <div class="info">
                    <span class="label">Done</span>
                    <span class="number"></span>
                </div>
            </div>

        </div>
    </div>


    <div id="body">

        <t t-if="props.tasks &amp;&amp; props.tasks.length">

            <t t-foreach="props.tasks" t-as="task" t-key="task.id">

                <t t-foreach="props.tasks" t-as="task" t-key="task.id">

    <div id="task_card">

        <!-- 🔥 PRIORITY EN HAUT -->
        <div id="task_priority">
            <span t-att-class="'priority_' + task.priority">
                <t t-if="task.priority == '0'">Low</t>
                <t t-if="task.priority == '1'">Normal</t>
                <t t-if="task.priority == '2'">High</t>
                <t t-if="task.priority == '3'">Urgent</t>
            </span>
        </div>

        <!-- 📌 NAME -->
        <h2 t-esc="task.name"/>

        <!-- 📄 DESCRIPTION -->
        <div>
            <i class="fa fa-align-left"></i>
            <span t-esc="task.description"/>
        </div>

        <!-- 👤 EMPLOYE -->
        <div>
            <i class="fa fa-user"></i>
            <span t-esc="task.assigned_to ? task.assigned_to[1] : ''"/>
        </div>

        <!-- 📅 DATES -->
        <div>
            <i class="fa fa-calendar"></i>
            <span t-esc="task.start_date"/>
        </div>

        <div>
            <i class="fa fa-calendar-check-o"></i>
            <span t-esc="task.end_date"/>
        </div>

        <!-- ⚙️ ACTIONS -->
        <div id="task_actions">
            <i class="fa fa-pencil"
               t-on-click="(ev) => props.editTask(ev)"
               t-att-data-id="task.id"/>

            <i class="fa fa-trash"
               t-on-click="(ev) => props.deleteTask(ev)"
               t-att-data-id="task.id"/>
        </div>

    </div>

</t>

                <!-- <div class="task_card">

                    <h3 t-esc="task.name"/>
                    <p t-esc="task.description"/>

                    <div class="task_actions">

                        <i class="fa fa-pencil icon"
                           t-att-data-id="task.id"
                        />

                        <i class="fa fa-trash icon"
                           t-att-data-id="task.id"/>

                    </div>

                </div> -->

            </t>

        </t>

        <t t-else="">
            <p>No tasks found</p>
        </t>

    </div>



