<odoo>

    <record id="view_project_kanban" model="ir.ui.view">
        <field name="name">society.project.kanban.pro</field>
        <field name="model">society.project</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="description"/>
                <field name="manager_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="task_count"/>
                <field name="progress"/>
                <field name="state"/>

                <templates>
                    <t t-name="card">
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_tasks"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-tasks">
                                <field name="task_count" widget="statinfo" string="Tasks"/>
                            </button>

                        </div>
                        <div class="oe_kanban_card oe_kanban_global_click p-2">
                            <!-- HEADER -->
                            <div class="d-flex justify-content-between">
                                <strong class="o_kanban_record_title">
                                    <field name="name"/>
                                </strong>
                                <span class="badge bg-info">
                                    <field name="state"/>
                                </span>
                            </div>
                            <!-- DESCRIPTION -->
                            <div class="mt8 text-muted">
                                <t t-if="record.description.raw_value">
                                    <field name="description"/>
                                </t>
                            </div>
                            <!-- DATES -->
                            <div class="mt8">
                                <div>
                                    📅 <b>Start Date:</b>
                                    <field name="start_date"/>
                                </div>
                                <div>
                                    🏁 <b>End Date:</b>
                                    <field name="end_date"/>
                                </div>
                            </div>
                            <!-- PROGRESS BAR -->
                            <div class="mt8">
                                <div class="progress">
                                    <div class="progress-bar bg-success"
                                         role="progressbar"
                                         t-att-style="'width:' + (record.progress.raw_value or 0) + '%'">
                                        <t t-esc="record.progress.raw_value"/>%
                                    </div>
                                </div>
                            </div>
                            <!-- FOOTER -->
                            <div class="o_kanban_footer mt8 d-flex justify-content-between align-items-center">
                                <div>
                                    📌 <field name="task_count"/> Tasks
                                </div>
                                <div>
                                    <field name="manager_id"
                                           widget="many2one_avatar_user"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>

        </field>
    </record>

</odoo>