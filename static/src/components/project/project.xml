<templates xml:space="preserve">
    <t t-name="society_management.project_dashboard_tag">
        <div class="project_dashboard">

            <div class="header" t-if="!state.showForm">
                <h1>📊 Project Dashboard</h1>
                <button class="create_project"  t-on-click="showCreateForm" >
                    Create New Project
                </button>
            </div>



    <!-- FORMULAIRE -->
           <t t-if="state.showForm">
            <ProjectForm
                state="state"
                saveProject.bind="saveProject"
                hideCreateForm.bind="hideCreateForm"/>
           </t>




            <t t-else="">
                <div class="body">
                <!-- TODO -->

                    <t t-foreach="projects" t-as="project" t-key="project.id">
                    <div class="project_card" >
                       <div class="project_state">
                            <span t-att-class="'state_'+project.state">
                                <t t-if="project.state == 'draft'">To Do</t>
                                <t t-if="project.state == 'progress'">In Progress</t>
                                <t t-if="project.state == 'done'">Done</t>
                                <t t-if="project.state == 'cancel'">Cancelled</t>
                            </span>
                       </div>
                        <h2 t-esc="project.name"/>

                        <div class="project_actions">
                             <i class="fa fa-eye icon"
                           title="voir"
                           style="color:green"
                           t-on-click="openProject"
                           t-att-data-id="project.id"/>

                            <i class="fa fa-pencil icon"
                               title="edit"
                               style="color:orange"
                               t-on-click="editProject"
                               t-att-data-id="project.id"/>

                            <i class="fa fa-trash icon"
                               title="delete"
                               style="color:red"
                               t-on-click="deleteProject"
                               t-att-data-id="project.id"/>
                        </div>

