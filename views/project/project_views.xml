<odoo>
    <data>
        <!-- PROJECT FORM VIEW -->

        <record id="view_society_project_form" model="ir.ui.view">
            <field name="name">society.project.form</field>
            <field name="model">society.project</field>
            <field name="arch" type="xml">
                <form string="Project">
                    <sheet>
                        <div class="dashboard_header">
                            <h1>
                                <field name="name"/>
                            </h1>
                        </div>
                        <div class="dashboard_stats">

                            <div class="stat_card">
                                <span class="stat_number">12</span>
                                <span class="stat_label">Tasks</span>
                            </div>

                            <div class="stat_card">
                                <span class="stat_number">5</span>
                                <span class="stat_label">Done</span>
                            </div>

                            <div class="stat_card">
                                <span class="stat_number">3</span>
                                <span class="stat_label">In Progress</span>
                            </div>

                        </div>

                        <notebook class="tasks_notebook">
                            <page string="Tasks">
                                <field name="task_ids">
                                    <list>
                                        <field name="name"/>
                                        <field name="assigned_to"/>
                                        <field name="state"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>


        <!-- PROJECT TREE VIEW -->

        <record id="view_society_project_tree" model="ir.ui.view">
            <field name="name">society.project.tree</field>
            <field name="model">society.project</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="client_id"/>
                    <field name="manager_id"/>
                </list>
            </field>
        </record>


        <!-- PROJECT ACTION -->

        <record id="society_project_action" model="ir.actions.act_window">
            <field name="name">Projects</field>
            <field name="res_model">society.project</field>
            <field name="view_mode">kanban,list,form</field>
        </record>

    </data>
</odoo>