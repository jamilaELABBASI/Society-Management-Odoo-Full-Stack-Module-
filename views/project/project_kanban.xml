<odoo>
    <data>

        <record id="view_project_kanban" model="ir.ui.view">
            <field name="name">society.project.kanban</field>
            <field name="model">society.project</field>
            <field name="arch" type="xml">

                <kanban default_group_by="state">

                    <field name="name"/>
                    <field name="client_id"/>
                    <field name="manager_id"/>
                    <field name="state"/>

                    <templates>
                        <t t-name="card">
                             <!-- HEADER -->
<!--                                <div class="kanban_header">-->
<!--                                    <strong>-->
<!--                                        <field name="name"/>-->
<!--                                    </strong>-->
<!--                                </div>-->
                            <div class="oe_kanban_card">



                                <div class="kanban_body">
                                    <strong>
                                    <field name="name"/>
                                </strong>

                                    <div>
                                        Client :
                                        <field name="client_id"/>
                                    </div>

                                    <div>
                                        Manager :
                                        <field name="manager_id"/>
                                    </div>
                                    <div>
                                        State :
                                        <field name="state"/>
                                    </div>
                                </div>
                                <!-- HEADER -->
<!--                                <div class="kanban_footer">-->
<!--                                    <strong>-->
<!--                                        <field name="name"/>-->
<!--                                    </strong>-->
<!--                                </div>-->
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

    </data>
</odoo>