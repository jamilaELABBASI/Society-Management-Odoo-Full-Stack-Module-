<odoo>
    <data>

        <record id="view_project_kanban" model="ir.ui.view">
            <field name="name">society.project.kanban</field>
            <field name="model">society.project</field>
            <field name="arch" type="xml">

                <kanban default_group_by="state">
                    <header>
                        <h1>Test</h1>
                    </header>

                    <field name="name"/>
                    <field name="client_id"/>
                    <field name="manager_id"/>
                    <field name="state"/>

                    <templates>
                        <t t-name="card">
                            <div class="oe_kanban_card">
                                <strong>
                                    <field name="name"/>
                                </strong>

                                <div>
                                    Client :
                                    <field name="client_id"/>
                                </div>

                                <div>
                                    Manager :
                                    <field name="manager_id"/>
                                </div>
                                <div>
                                    State :
                                    <field name="state"/>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

    </data>
</odoo>