<odoo>
    <record id="group_employee" model="res.groups">
        <field name="name">Employee</field>
    </record>
     <record id="group_manager" model="res.groups">
        <field name="name">Manager</field>
    </record>
    <record id="group_director" model="res.groups">
        <field name="name">Director</field>
    </record>

    <record id="task_rule_employee" model="ir.rule">
    <field name="name">Employee sees assigned tasks</field>
    <field name="model_id" ref="society_management.model_society_task"/>
    <field name="domain_force">[('assigned_to','=',user.id)]</field>
    <field name="groups" eval="[(4, ref('society_management.group_employee'))]"/>
</record>

<record id="project_rule_manager" model="ir.rule">
    <field name="name">Manager sees own projects</field>
    <field name="model_id" ref="society_management.model_society_project"/>
    <field name="domain_force">[('manager_id','=',user.id)]</field>
    <field name="groups" eval="[(4, ref('society_management.group_manager'))]"/>
</record>

</odoo>