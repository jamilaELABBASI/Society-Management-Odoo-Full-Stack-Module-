<odoo>
    <record id="task_rule_employee" model="ir.rule">
        <field name="name">Employee sees assigned tasks</field>
        <field name="model_id" ref="society_management.model_society_task"/>
        <field name="domain_force">[('assigned_to','=',user.id)]</field>
        <field name="groups" eval="[(4, ref('society_management.group_employee'))]"/>
    </record>

    <record id="rule_manager_projects" model="ir.rule">
    <field name="name">Manager sees own projects</field>
    <field name="model_id" ref="model_society_project"/>
    <field name="groups" eval="[(4, ref('society_management.group_manager'))]"/>
    <field name="domain_force">
        ['|',
            ('manager_id', '=', user.id),
            ('manager_id', '=', False)
        ]
    </field>
</record>
</odoo>