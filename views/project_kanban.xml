<odoo>
    <record id="view_project_kanban_pro" model="ir.ui.view">
        <field name="name">society.project.kanban.pro</field>
        <field name="model">society.project</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_small_column">

                <field name="name"/>
                <field name="description"/>
                <field name="manager_id"/>
                <field name="state"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="progress"/>
                <field name="is_late"/>

                <templates>
                    <t t-name="card">

                        <div t-att-class="'o_kanban_record shadow rounded-4 p-3 ' + (record.is_late.raw_value and 'border border-danger' or '')">

                            <!-- HEADER -->
                            <div class="d-flex justify-content-between align-items-center mb-2">

                                <h5 class="fw-bold mb-0">
                                    <field name="name"/>
                                </h5>

                                <!-- Badge dynamique -->
                                <t t-if="record.state.raw_value == 'draft'">
                                    <span class="badge bg-secondary">Draft</span>
                                </t>
                                <t t-if="record.state.raw_value == 'in_progress'">
                                    <span class="badge bg-warning text-dark">In Progress</span>
                                </t>
                                <t t-if="record.state.raw_value == 'done'">
                                    <span class="badge bg-success">Done</span>
                                </t>
                            </div>

                            <!-- DESCRIPTION -->
                            <t t-if="record.description.raw_value">
                                <p class="text-muted small mb-3">
                                    <field name="description"/>
                                </p>
                            </t>

                            <!-- PROGRESS BAR intelligente -->
                            <div class="mb-3">
                                <div class="progress" style="height: 6px;">
                                    <div class="progress-bar"
                                         t-att-class="'progress-bar ' +
                                         (record.progress.raw_value &lt; 50 and 'bg-danger' or
                                          record.progress.raw_value &lt; 100 and 'bg-warning' or
                                          'bg-success')"
                                         role="progressbar"
                                         t-att-style="'width: ' + record.progress.raw_value + '%;'">
                                    </div>
                                </div>
                                <small class="text-muted">
                                    <t t-esc="record.progress.raw_value"/>%
                                </small>
                            </div>

                            <!-- Dates -->
                            <div class="small text-muted mb-2">
                                <i class="fa fa-calendar me-1"/>
                                <field name="start_date"/> → <field name="end_date"/>
                            </div>

                            <!-- RETARD ALERT -->
                            <t t-if="record.is_late.raw_value">
                                <div class="text-danger small fw-bold">
                                    ⚠ Late Project
                                </div>
                            </t>

                            <!-- FOOTER -->
                            <div class="d-flex justify-content-between align-items-center mt-3">

                                <t t-if="record.manager_id.raw_value">
                                    <field name="manager_id"
                                           widget="many2one_avatar_user"/>
                                </t>

                                <i class="fa fa-folder-open text-secondary"/>
                            </div>

                        </div>

                    </t>
                </templates>

            </kanban>
        </field>
    </record>
</odoo>