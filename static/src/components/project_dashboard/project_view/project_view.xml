<t t-name="society_management.project_view">

    <div id="view_container">
         <div id="icon">
                <i class="fa fa-close" t-on-click="props.hideCreateForm"></i>
            </div>
        <div id="view">

          <div>
              <i class="fa fa-folder"></i>
              <strong>Name</strong>
              <p t-esc="props.state.form.name"/>
          </div>
            <div>
              <i class="fa fa-align-left"></i>
                <strong>Description</strong>
                <p t-esc="props.state.form.description"/>
            </div>

            <div>
              <i class="fa fa-user"></i>
                <strong>Manager</strong>
                <p t-esc="props.state.form.manager_name"/>
            </div>
            <div>
              <i class="fa fa-calendar"></i>
                <strong>Start Date</strong>
                                <p t-esc="props.state.form.start_date"/>
            </div>
            <div>
              <i class="fa fa-calendar-check-o"></i>
                <strong>End Date</strong>
                                <p t-esc="props.state.form.end_date"/>
            </div>
            <div>
              <i class="fa fa-tasks"></i>
                                <strong>Status</strong>
                <p t-esc="props.state.form.state"/>
            </div>

        </div>
    </div>

</t>