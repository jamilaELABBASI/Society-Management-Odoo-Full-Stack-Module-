<t t-name="society_management.task_dashboard">

    <button id="create_task" t-on-click="props.showTaskForm">
        Create Task
    </button>

    <div id="tasks">

        <t t-if="props.tasks?.length">

            <t t-foreach="props.tasks" t-as="task" t-key="task.id">

                <div id="task_card">

                    <div id="task_state">
                        <span t-att-class="'state_' + task.priority">
                            <t t-if="task.priority == '0'">Low</t>
                            <t t-if="task.priority == '1'">Normal</t>
                            <t t-if="task.priority == '2'">High</t>
                            <t t-if="task.priority == '3'">Urgent</t>
                        </span>
                    </div>

                    <h1 t-esc="task.name"/>

                     <div>
                    <i class="fa fa-align-left"></i>
                    <strong>Description</strong>
                    <span t-esc="task.description"/>
                </div>

                <div>
                  <i class="fa fa-user"></i>
                    <strong>Manager</strong>
                    <span t-esc="task.assigned_to[1]"/>
                </div>
                <div>
                  <i class="fa fa-calendar"></i>
                    <strong>Start Date</strong>
                    <span t-esc="task.start_date"/>
                </div>
                <div>
                  <i class="fa fa-calendar-check-o"></i>
                    <strong>End Date</strong>
                    <span t-esc="task.end_date"/>
                </div>
                <div>
                  <i class="fa fa-tasks"></i>
                    <strong>Status</strong>
                    <span t-esc="task.state"/>
                </div>

                    <div id="task_actions">

                                <i class="fa fa-pencil" style="color:orange"
                                   t-on-click="props.editTask"
                                   t-att-data-id="task.id"/>

                                <i class="fa fa-trash" style="color:red"
                                   t-on-click="props.deleteTask"
                                   t-att-data-id="task.id"/>
                            </div>


                </div>

            </t>

        </t>

        <t t-else="">
            <p>No tasks</p>
        </t>

    </div>

</t>