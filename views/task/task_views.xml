<odoo>
    <data>

        <!-- ACTION -->
        <record id="society_task_action" model="ir.actions.act_window">
            <field name="name">Tasks</field>
            <field name="res_model">society.task</field>
            <field name="view_mode">kanban,list,form</field>
        </record>


        <!-- TREE VIEW -->
        <record id="view_society_task_tree" model="ir.ui.view">
            <field name="name">society.task.tree</field>
            <field name="model">society.task</field>
            <field name="arch" type="xml">

                <list string="Tasks">
                    <field name="name"/>
                    <field name="project_id"/>
                    <field name="assigned_to"/>
                    <field name="state"/>
                </list>

            </field>
        </record>


        <!-- FORM VIEW -->
        <record id="view_society_task_form" model="ir.ui.view">
            <field name="name">society.task.form</field>
            <field name="model">society.task</field>
            <field name="arch" type="xml">

                <form string="Task">
                    <sheet>

                        <group>
                            <field name="name"/>
                            <field name="project_id"/>
                            <field name="assigned_to"/>
                            <field name="state"/>
                        </group>

                    </sheet>
                </form>

            </field>
        </record>

    </data>
</odoo>